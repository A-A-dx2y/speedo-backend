{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    /* Environment Settings */
    "module": "NodeNext",
    "target": "es2020",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "lib": [
      "es2020"
    ],
    /* Other Outputs */
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    /* Stricter Typechecking */
    "noUncheckedIndexedAccess": true,
    /* Recommended Options */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    /* Experimental Features */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "ts-node": {
    "files": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}